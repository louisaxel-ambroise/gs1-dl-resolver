meta {
  name: Remove a redirection link for a DigitalLink
  type: http
  seq: 2
}

delete {
  url: {{BaseUrl}}/api/register
  body: json
  auth: none
}

body:json {
  {
    "prefix": "{{digitalLink}}",
    "linkTypes": ["gs1:pip"],
    "language": "en-US"
  }
}

vars:pre-request {
  digitalLink: /01/05414195535264
}
