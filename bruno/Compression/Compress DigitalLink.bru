meta {
  name: Compress DigitalLink
  type: http
  seq: 1
}

post {
  url: {{BaseUrl}}/api/compress
  body: json
  auth: none
}

headers {
  x-compression-type: {{compressionType}}
}

body:json {
  {
    "DigitalLink": "{{digitalLink}}",
    "CompressionType": "{{compressionType}}",
    "CompressQueryString": true
  }
}

vars:pre-request {
  digitalLink: 01/05414195535264/21/1234
  compressionType: Full
}
