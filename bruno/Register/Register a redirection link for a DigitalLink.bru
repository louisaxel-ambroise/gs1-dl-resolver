meta {
  name: Register a redirection link for a DigitalLink
  type: http
  seq: 1
}

post {
  url: {{BaseUrl}}/api/register
  body: json
  auth: none
}

body:json {
  {
    "prefix":"{{digitalLink}}",
    "title":"Test desc",
    "redirectUrl":"https://example.org{?gtin}",
    "linkTypes": ["gs1:pip"],
    "language":"en-US"
  }
}

vars:pre-request {
  digitalLink: /01/05414195535264
}
